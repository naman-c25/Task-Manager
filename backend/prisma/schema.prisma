// Prisma schema - PostgreSQL
// Dev me `npm run prisma:migrate` chalao, production (CI/Render) me `npm run prisma:deploy`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(60)
  // @unique se B-tree index ban jaata hai, isliye email lookup (login, uniqueness check) O(log n) hota hai na ki pura table scan
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks Task[]

  // Postgres convention ke hisaab se snake_case table name
  @@map("users")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  title       String     @db.VarChar(160)
  description String?    @db.VarChar(2000)
  status      TaskStatus @default(TODO)
  userId      String     @map("user_id") @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Board hamesha "mere tasks, is column ke" query karta hai, isliye (user_id, status) pe composite index lagaya hai - ye reads fast rehti hain
  @@index([userId, status])
  @@map("tasks")
}
