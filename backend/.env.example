# ───────────────────────────────────────────────────────────
# Server
# ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Comma-separated list of allowed origins for CORS
CLIENT_ORIGIN=http://localhost:5173

# ───────────────────────────────────────────────────────────
# Database (PostgreSQL via Prisma)
#   Append ?connection_limit=10 to tune the pool size for your host.
#   Managed Postgres (Neon/Supabase/Render) usually requires ?sslmode=require
#
#   Note: docker-compose maps Postgres to host port 5433 to avoid clashing with
#   a natively-installed PostgreSQL on 5432. Use 5432 if you're NOT running Docker
#   (and have no other Postgres on that port).
# ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/task_manager?schema=public

# ───────────────────────────────────────────────────────────
# Cache / Redis
# ───────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
# Seconds to cache a user profile (read-through cache for /auth/me)
USER_CACHE_TTL=300

# ───────────────────────────────────────────────────────────
# Authentication (use long, random strings in production)
#   Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_ACCESS_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
